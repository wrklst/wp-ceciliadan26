{
    "key": "group_page_content",
    "title": "Page Content",
    "fields": [
        {
            "key": "field_page_content_sections",
            "label": "Sections",
            "name": "page_content_sections",
            "type": "flexible_content",
            "button_label": "Add Section",
            "layouts": {
                "text_block": {
                    "key": "layout_text_block",
                    "name": "text_block",
                    "label": "Text Block",
                    "display": "block",
                    "sub_fields": [
                        {
                            "key": "field_text_block_headline",
                            "label": "Headline",
                            "name": "headline",
                            "type": "text"
                        },
                        {
                            "key": "field_text_block_headline_visible",
                            "label": "Show headline visually",
                            "name": "headline_visible",
                            "type": "true_false",
                            "instructions": "When off, the headline is hidden visually but remains accessible to screen readers, search engines, and AI.",
                            "default_value": 1,
                            "ui": 1
                        },
                        {
                            "key": "field_text_block_content",
                            "label": "Content",
                            "name": "content",
                            "type": "wysiwyg",
                            "tabs": "all",
                            "toolbar": "full",
                            "media_upload": 0
                        }
                    ]
                },
                "accordion_block": {
                    "key": "layout_accordion_block",
                    "name": "accordion_block",
                    "label": "Accordion Block",
                    "display": "block",
                    "sub_fields": [
                        {
                            "key": "field_accordion_block_headline",
                            "label": "Headline",
                            "name": "headline",
                            "type": "text"
                        },
                        {
                            "key": "field_accordion_block_headline_visible",
                            "label": "Show headline visually",
                            "name": "headline_visible",
                            "type": "true_false",
                            "instructions": "When off, the headline is hidden visually but remains accessible to screen readers, search engines, and AI.",
                            "default_value": 1,
                            "ui": 1
                        },
                        {
                            "key": "field_accordion_block_items",
                            "label": "Items",
                            "name": "items",
                            "type": "repeater",
                            "button_label": "Add Item",
                            "layout": "block",
                            "sub_fields": [
                                {
                                    "key": "field_accordion_item_headline",
                                    "label": "Headline",
                                    "name": "headline",
                                    "type": "text"
                                },
                                {
                                    "key": "field_accordion_item_hash",
                                    "label": "Hash",
                                    "name": "hash",
                                    "type": "text",
                                    "instructions": "URL fragment for direct linking (e.g., \"advising\" creates #advising). Lowercase, no spaces.",
                                    "placeholder": "advising"
                                },
                                {
                                    "key": "field_accordion_item_lead_text",
                                    "label": "Lead Text",
                                    "name": "lead_text",
                                    "type": "textarea",
                                    "instructions": "Short introductory paragraph shown when the accordion item is collapsed.",
                                    "rows": 3,
                                    "new_lines": "br"
                                },
                                {
                                    "key": "field_accordion_item_copy_text",
                                    "label": "Copy Text",
                                    "name": "copy_text",
                                    "type": "textarea",
                                    "instructions": "Extended content revealed when the accordion item is expanded.",
                                    "rows": 8,
                                    "new_lines": "wpautop"
                                }
                            ]
                        }
                    ]
                },
                "team_block": {
                    "key": "layout_team_block",
                    "name": "team_block",
                    "label": "Team Block",
                    "display": "block",
                    "sub_fields": [
                        {
                            "key": "field_team_block_headline",
                            "label": "Headline",
                            "name": "headline",
                            "type": "text"
                        },
                        {
                            "key": "field_team_block_headline_visible",
                            "label": "Show headline visually",
                            "name": "headline_visible",
                            "type": "true_false",
                            "instructions": "When off, the headline is hidden visually but remains accessible to screen readers, search engines, and AI.",
                            "default_value": 1,
                            "ui": 1
                        },
                        {
                            "key": "field_team_block_members",
                            "label": "Members",
                            "name": "members",
                            "type": "repeater",
                            "button_label": "Add Member",
                            "layout": "block",
                            "sub_fields": [
                                {
                                    "key": "field_team_member_name",
                                    "label": "Name",
                                    "name": "name",
                                    "type": "text"
                                },
                                {
                                    "key": "field_team_member_position",
                                    "label": "Position",
                                    "name": "position",
                                    "type": "text",
                                    "placeholder": "e.g., Art Advisor & Accredited Senior Appraiser"
                                },
                                {
                                    "key": "field_team_member_email",
                                    "label": "Email",
                                    "name": "email",
                                    "type": "email"
                                },
                                {
                                    "key": "field_team_member_lead_text",
                                    "label": "Lead Text",
                                    "name": "lead_text",
                                    "type": "textarea",
                                    "instructions": "Short introductory paragraph shown when collapsed.",
                                    "rows": 3,
                                    "new_lines": "br"
                                },
                                {
                                    "key": "field_team_member_copy_text",
                                    "label": "Copy Text",
                                    "name": "copy_text",
                                    "type": "textarea",
                                    "instructions": "Extended biography revealed when expanded.",
                                    "rows": 8,
                                    "new_lines": "wpautop"
                                }
                            ]
                        }
                    ]
                },
                "image_block": {
                    "key": "layout_image_block",
                    "name": "image_block",
                    "label": "Image Block",
                    "display": "block",
                    "sub_fields": [
                        {
                            "key": "field_image_block_headline",
                            "label": "Headline",
                            "name": "headline",
                            "type": "text"
                        },
                        {
                            "key": "field_image_block_headline_visible",
                            "label": "Show headline visually",
                            "name": "headline_visible",
                            "type": "true_false",
                            "instructions": "When off, the headline is hidden visually but remains accessible to screen readers, search engines, and AI.",
                            "default_value": 1,
                            "ui": 1
                        },
                        {
                            "key": "field_image_block_image",
                            "label": "Image",
                            "name": "image",
                            "type": "image",
                            "return_format": "id",
                            "preview_size": "content-medium",
                            "library": "all"
                        },
                        {
                            "key": "field_image_block_caption",
                            "label": "Caption",
                            "name": "caption",
                            "type": "text",
                            "instructions": "Photo credit or description shown below the image."
                        }
                    ]
                },
                "list_block": {
                    "key": "layout_list_block",
                    "name": "list_block",
                    "label": "List Block",
                    "display": "block",
                    "sub_fields": [
                        {
                            "key": "field_list_block_headline",
                            "label": "Headline",
                            "name": "headline",
                            "type": "text"
                        },
                        {
                            "key": "field_list_block_headline_visible",
                            "label": "Show headline visually",
                            "name": "headline_visible",
                            "type": "true_false",
                            "instructions": "When off, the headline is hidden visually but remains accessible to screen readers, search engines, and AI.",
                            "default_value": 1,
                            "ui": 1
                        },
                        {
                            "key": "field_list_block_text",
                            "label": "Text",
                            "name": "text",
                            "type": "textarea",
                            "rows": 3,
                            "new_lines": "wpautop"
                        },
                        {
                            "key": "field_list_block_text_visible",
                            "label": "Show text visually",
                            "name": "text_visible",
                            "type": "true_false",
                            "instructions": "When off, the text is hidden visually but remains accessible to screen readers, search engines, and AI.",
                            "default_value": 1,
                            "ui": 1
                        },
                        {
                            "key": "field_list_block_groups",
                            "label": "Groups",
                            "name": "groups",
                            "type": "repeater",
                            "button_label": "Add Group",
                            "layout": "block",
                            "sub_fields": [
                                {
                                    "key": "field_list_group_headline",
                                    "label": "Headline",
                                    "name": "headline",
                                    "type": "text"
                                },
                                {
                                    "key": "field_list_group_items",
                                    "label": "Items",
                                    "name": "items",
                                    "type": "repeater",
                                    "button_label": "Add Item",
                                    "layout": "table",
                                    "sub_fields": [
                                        {
                                            "key": "field_list_item_name",
                                            "label": "Name",
                                            "name": "name",
                                            "type": "text"
                                        },
                                        {
                                            "key": "field_list_item_url",
                                            "label": "URL",
                                            "name": "url",
                                            "type": "url"
                                        }
                                    ]
                                }
                            ]
                        }
                    ]
                }
            }
        }
    ],
    "location": [
        [
            {
                "param": "post_type",
                "operator": "==",
                "value": "page"
            }
        ]
    ],
    "menu_order": 0,
    "position": "normal",
    "style": "seamless",
    "label_placement": "top",
    "instruction_placement": "label",
    "active": true,
    "hide_on_screen": ["the_content"]
}
